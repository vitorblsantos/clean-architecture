HOST=localhost

# Compose app: host.docker.internal (DB no host) | postgres (--profile dev) | IP remoto
# Local: localhost
DATABASE_HOST=host.docker.internal
DATABASE_NAME=clean-arch
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=true
DATABASE_TIMEZONE='America/Sao_Paulo'
DATABASE_USER=postgres

# App no Docker Compose: kafka:9092 | no host (yarn dev): localhost:29092
# Local: localhost:29092
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=argus
KAFKA_TOPIC_PROFILES_SYNC=profiles.sync
KAFKA_TOPIC_PROFILES_SYNC_DLQ=profiles.sync.dlq

NODE_ENV=local

PORT=8080

# App no Docker Compose: redis:6379 | no host (yarn dev): localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional — omit for local Redis without auth
REDIS_PASSWORD=1234
REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=false
